# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5500

# MongoDB Atlas connection string
# Get this from Atlas: Database > Connect > Drivers
MONGO_URI=mongodb+srv://aiassistant:assistant123@cluster0.zhwx0g0.mongodb.net/?appName=Cluster0


# JWT
JWT_SECRET=secretkey123456
JWT_EXPIRES_IN=7d

# Groq API key (free tier, no credit card required)
# Get one at https://console.groq.com/keys
GROQ_API_KEY=
# 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
GROQ_MODEL=openai/gpt-oss-120b
# Lighter/quicker alternative offered as the "Fast" option in chat.
GROQ_FAST_MODEL=openai/gpt-oss-20b
# Used automatically when a message includes an image attachment.
# Groq's vision lineup changes often -- check https://console.groq.com/docs/models
# if uploads start failing with a "model_decommissioned" error.
GROQ_VISION_MODEL=qwen/qwen3.6-27b

